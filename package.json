{
  "name": "api-sua-bcv",
  "type": "module",
  "private": true,
  "author": "SUA",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sua7Dev/api-bcv-sua.git"
  },
  "scripts": {
    "dev": "bunx vite --config vite.api.config.js",
    "build": "bun run docs:build && bun run data:copy && bun run api:build",
    "serve": "bunx vite preview",
    "api:build": "bunx vite build --config vite.api.config.js --ssr --mode=production",
    "docs:dev": "bunx vitepress dev docs",
    "docs:build": "bunx vitepress build docs",
    "docs:preview": "bunx vitepress preview docs",
    "docs:i18n-extract": "bunx vue-i18n-extract report --vueFiles './docs/.vitepress/**/*.?(js|vue|md)' --languageFiles './docs/.vitepress/theme/locales/*.?(json|yml|yaml)'",
    "docs:gen": "bun run scripts/generadores/generar.js",
    "format": "prettier --write '**/*.js'",
    "data:copy": "bun run scripts/datos.js",
    "seed:ve": "bun run scripts/seed-ve-db.js",
    "cron:build": "bunx vite build --config vite.config.js --ssr --mode=production",
    "cron:run": "bun run ./cron/index.js",
    "cron:test": "bunx vitest --config vite.config.js",
    "cron:test:ui": "bunx vitest --ui",
    "cron:test:run": "bunx vitest run",
    "og:dev": "bunx x-satori -t ./og/Template.vue -c og/config.js --dev",
    "og:build": "bunx x-satori -t ./og/Template.vue -c og/config.js -o image.svg",
    "og:png": "bun run og/gen-png.js"
  },
  "dependencies": {
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.4",
    "better-sqlite3": "^12.5.0",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.4.1",
    "@egoist/tailwindcss-icons": "^1.9.0",
    "@faker-js/faker": "^10.1.0",
    "@fontsource/inter": "^5.2.8",
    "@hono/vite-dev-server": "^0.23.0",
    "@iconify-json/mdi": "^1.2.3",
    "@intlify/unplugin-vue-i18n": "^11.0.1",
    "@observablehq/plot": "^0.6.17",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^20.19.25",
    "@vueuse/core": "^14.1.0",
    "autoprefixer": "^10.4.22",
    "axios": "^1.13.2",
    "cheerio": "1.0.0-rc.12",
    "collect.js": "^4.36.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-import": "^2.32.0",
    "genji-theme-vitepress": "^0.2.8",
    "hono": "^4.10.7",
    "iconv-lite": "^0.7.0",
    "parse-decimal-number": "^1.0.0",
    "pino": "^10.1.0",
    "pino-axiom": "^1.0.432",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "prettier": "3.0.3",
    "sitemap": "^9.0.0",
    "tailwindcss": "^3.4.3",
    "try-to-catch": "^3.0.1",
    "tsx": "3.12.7",
    "typescript": "^5.9.3",
    "vercel": "^48.12.1",
    "vite": "^7.2.6",
    "vitepress": "^1.6.4",
    "vitepress-openapi": "^0.1.16",
    "vitest": "^3.2.4",
    "vue": "^3.5.25",
    "vue-i18n": "^11.2.2",
    "x-satori": "0.1.5"
  }
}
