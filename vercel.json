{
  "version": 2,
  "outputDirectory": "dist/static/",
  "functions": {
    "api/index.js": {
      "runtime": "edge",
      "includeFiles": "dist/servidor/**"
    }
  },
  "rewrites": [
    {
      "source": "/v1/:moneda",
      "destination": "/api/index.js"
    },
    {
      "source": "/v1/:moneda/:subpath",
      "destination": "/api/index.js"
    },
    {
      "source": "/cron/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "headers": [
    {
      "source": "/v1/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, s-maxage=60, stale-while-revalidate=30"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
